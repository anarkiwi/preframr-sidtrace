diff --git a/src/c64/membus_trace.h b/src/c64/membus_trace.h
new file mode 100644
index 00000000..3598f1f8
--- /dev/null
+++ b/src/c64/membus_trace.h
@@ -0,0 +1,1892 @@
+/*
+ * membus_trace.h - in-emulator DISTILLER for white-box SID recovery.
+ * Not part of upstream libsidplayfp. Scratch use only.
+ *
+ * The OLD design streamed every CPU bus cycle to disk (a multi-GB raw trace per
+ * tune) and partitioned it offline in Python -- hopeless at 60,000 tunes. This
+ * recorder instead DISTILLS the execution IN the emulator into a few-KB
+ * structured artifact and emits it once, at the end of the run. Nothing is
+ * streamed; peak memory is bounded by a handful of 64 KiB arrays plus small maps.
+ *
+ * What it accumulates (see SDST artifact format in sidtrace.cpp / the Python
+ * reader bacc/generic/distill.py):
+ *
+ *  - Per-address ACCESS-TYPE map (the SMC-correct classifier). For every address
+ *    the recorder ORs in, per phase (init / play), the access kinds it saw:
+ *    instruction-fetch (EXEC), data-read (READ), data-write (WRITE). The CPU
+ *    core marks an opcode/operand fetch via recordFetch(); ordinary operand and
+ *    data cycles come through record(). From these:
+ *      SMC          = EXEC_PLAY & WRITE_PLAY  (a location both executed AND
+ *                     written during play -- self-modifying code, NOT song data)
+ *      song-data    = READ_PLAY & !WRITE_PLAY & !EXEC (read as data during play,
+ *                     never written during play, never executed -- the
+ *                     init/load-resident table the player only reads).
+ *    Classifying by access TYPE (not by the fragile write-set subtraction) is
+ *    what makes SMC handling correct: SMC operand writes are code modification,
+ *    excluded from song data because the location is also EXEC, not because we
+ *    happened to see a write.
+ *
+ *  - Post-init RAM SNAPSHOT. At the init->play boundary the host calls
+ *    snapshotRam(); the recorder copies the live 64 KiB image (via a host getter)
+ *    so the song bytes are captured verbatim once, not reconstructed from writes.
+ *
+ *  - PC-tagged SID-write summary. Per (issuing PC, SID register) the count and a
+ *    representative value -- voice-lane attribution by code identity, a few dozen
+ *    entries, not every cycle.
+ *
+ *  - Indexed-read / table-access summary (VSA-style). Per issuing PC of an
+ *    indexed read, the base (= effective addr - index), element stride, index
+ *    min/max, and access count -- surfaces table base / element-size / length /
+ *    traversal without the raw read stream.
+ *
+ *  - Per-SID-write DATA-FLOW summary (SIDDF). Keyed by (issuing PC, SID register)
+ *    -- the SAME key space as the PC-tagged SID-write summary, so it is O(code
+ *    sites), NOT O(frames). For each distinct STA $D4xx code site, a BOUNDED
+ *    backward dynamic slice is walked, in-emulator, over a small ring buffer of
+ *    the last ~few-hundred RETIRED instructions of the current play-call. The
+ *    slice follows data edges (store <- last def of the value reg; load <- last
+ *    writer of the loaded address, which may be a prior frame -> persistent
+ *    state; ALU ops <- their operands; indexed reads <- the def of the index
+ *    reg). It records, per (PC,reg): the set of PCs in the slice (the generator's
+ *    code), the classified leaf kinds (immediate / ram_read / state_cell[=SMC] /
+ *    exogenous, via the access-type map), a strided-interval VSA for any indexed
+ *    read feeding THIS write, the ALU op sequence on the value-defining chain,
+ *    and min/max/first written value. This turns "we know THAT this PC wrote the
+ *    register" into "we know HOW it computed it" -- the per-write computation DAG
+ *    the recurrence-recovery host needs -- while staying a few KB and FLAT vs run
+ *    length. A leaf whose def-chain exits the ring-buffer window is recorded
+ *    honestly as out-of-window, never by unbounding the buffer.
+ *
+ * A process-global singleton. The c64 object registers getters for the cycle,
+ * the issuing PC, the index register, and the RAM image; the host (sidtrace.cpp)
+ * sets the phase around the init/play calls and triggers the post-init snapshot.
+ * Logging is gated by 'enabled' so normal playback stays fast.
+ */
+#ifndef MEMBUS_TRACE_H
+#define MEMBUS_TRACE_H
+
+#include <cstdint>
+#include <cstdio>
+#include <cstring>
+#include <map>
+#include <utility>
+#include <vector>
+
+namespace libsidplayfp
+{
+
+// Execution phase a record was issued in (host-set).
+enum MemPhase : uint8_t
+{
+    PHASE_BOOT = 0,   // emulator boot / before the tune's init call
+    PHASE_INIT = 1,   // inside the tune init (subtune select / table depack)
+    PHASE_PLAY = 2,   // steady per-frame play loop
+};
+
+// Per-address access-type accumulator bits (the SMC-correct classifier).
+enum AccBits : uint8_t
+{
+    ACC_EXEC_INIT  = 1 << 0,  // fetched as code during init
+    ACC_READ_INIT  = 1 << 1,  // read as data during init
+    ACC_WRITE_INIT = 1 << 2,  // written during init
+    ACC_EXEC_PLAY  = 1 << 3,  // fetched as code during play
+    ACC_READ_PLAY  = 1 << 4,  // read as data during play
+    ACC_WRITE_PLAY = 1 << 5,  // written during play
+};
+
+// One PC-tagged SID-register-write summary entry.
+struct SidWrSummary
+{
+    uint64_t count = 0;
+    uint8_t  lastVal = 0;   // representative (most recent) value written
+};
+
+// One timestamped SID register write (for the per-frame render/dump gate). This
+// is the ONLY timestamped stream kept -- it is tiny (one ~25-write burst per
+// frame), unlike the retired multi-GB full bus trace.
+struct SidWrEvent
+{
+    int64_t  cycle;
+    uint16_t addr;
+    uint8_t  reg;
+    uint8_t  val;
+};
+
+// One indexed-read (VSA) summary entry, keyed by issuing PC.
+struct IdxSummary
+{
+    uint64_t count = 0;
+    uint16_t base = 0;       // effective addr - index at first sighting
+    int32_t  strideGuess = 0;// dominant inter-access address delta (best effort)
+    uint16_t lastAddr = 0;
+    uint8_t  idxMin = 0xff;
+    uint8_t  idxMax = 0;
+    bool     baseSet = false;
+
+    // --- SCALED-INDEX fit (recovery-offload item #1) ----------------------
+    // The single-sample `base = effAddr - idx` is only correct when the table
+    // stride matches the index step. For a `LDA tbl,Y` whose Y is pre-scaled
+    // (Y = note*2 into a stride-2 interleaved table) the recovered base is
+    // garbled. We record up to two DISTINCT-index observed (idxVal, effAddr)
+    // samples USING THE OPCODE'S ACTUAL INDEX REGISTER (not max(x,y), which
+    // mis-attributes the base when the other index reg happens to be larger),
+    // so the host can fit  scale = (a1-a0)/(i1-i0),  base = a0 - scale*i0
+    // and read the interleaved note/pointer table at the right stride. Two
+    // samples with distinct idx are sufficient for the affine fit; idxSamples
+    // holds them and scaleSet flags a valid fit.
+    uint8_t  sampIdx[2] = {0, 0};
+    uint16_t sampAddr[2] = {0, 0};
+    uint8_t  nSamp = 0;
+    bool     scaleSet = false;
+    int32_t  scale = 1;       // fitted bytes-per-index step (0 if not fittable)
+    uint16_t baseFit = 0;     // fitted base = sampAddr[0] - scale*sampIdx[0]
+
+    // --- feedsRegMask (recovery-offload item #5) --------------------------
+    // Which SID $D4xx register(s) this table's values ultimately feed (a bit
+    // per reg 0..24). Propagated from the SIDDF SID-write slicer when a slice
+    // reaches this PC's indexed read as a leaf (the freq/instrument/etc. lane
+    // attribution the slice machinery already holds). Plus two table-class
+    // signals: targetsInImage (the 16-bit values formed at base+idx are
+    // themselves in-image addresses -> a pointer table) and targetsReadAsData
+    // (those target addresses were READ AS DATA during play -> a live pointer
+    // table the player dereferenced). Both default false; set at finalize.
+    uint32_t feedsRegMask = 0;
+    bool     targetsInImage = false;
+    bool     targetsReadAsData = false;
+
+    // --- IWLK per-frame walk-index (the freq-modulation generator input) ----
+    // For a freq-feeding direct-indexed read, the SEQUENCE of (frame, index)
+    // samples -- the per-play-call index the playroutine walked into the RAM
+    // instrument freq-table. The host (PR-A reader / PR-C fitter) densifies this
+    // to a full-length per-frame array (forward-filling a held frame with the
+    // prior index) and recovers freq = note_base + instr_freq_table[index],
+    // retriggered at note onset -- rather than storing the per-frame freq lane
+    // (HARD RULE #0). ONE sample per frame (the last qualifying read that frame),
+    // guarded by lastIdxFrame; emitted only for freq-feeding PCs at finalize.
+    std::vector<std::pair<uint32_t, uint8_t>> idxFrameSamples;
+    uint32_t lastIdxFrame = 0xffffffff;  // de-dup guard: one sample per frame
+};
+
+// --- PWLK ((zp),Y pointer-walk capture; recovery-offload item #2) ----------
+// A `(zp),Y` indirect-indexed access (opcodes 0xB1 load / 0x91 store) reads its
+// 16-bit pointer live from the zero-page pair `ram(zp) | ram(zp+1)<<8`. The
+// SEQUENCE of distinct pointer values this zp-pair takes across the run IS the
+// resolved orderlist->pattern stream (each new pointer = a pattern start the
+// orderlist advanced to); the Y index range per pointer is the row span walked;
+// the frame index of each advance is a note/row onset. Keyed by the zp-pair base
+// address. Dedup consecutive-equal pointer values into ADVANCE events.
+//
+// FULL-LENGTH (recovery campaign): the advance sequence is the resolved
+// orderlist->pattern SCHEDULE; truncating it (the old 256-advance cap) loses the
+// tail of the song (real advance counts: Music_Assembler 10759, GoatTracker
+// 2726). The recovery needs the whole schedule, so we keep the advances in a
+// growable vector -- not flat vs run length, but the schedule IS the program the
+// recovery recovers (a few KB of u16/u32 per zp-pair, one per orderlist pointer,
+// dwarfed by the resolved-pattern saving it unblocks). The on-disk nAdv field is
+// u16, so a pathological pair with >65535 advances would saturate; PW_CAP caps
+// the in-memory growth at that ceiling to keep the emit lossless-or-saturated
+// rather than silently truncated to 256.
+struct PtrWalkCell
+{
+    static constexpr uint32_t PW_CAP = 65535;  // u16 nAdv ceiling (emit field width)
+    std::vector<uint16_t> ptrVals;            // distinct consecutive pointer values
+    std::vector<uint32_t> advFrame;           // frame (play-call) index of each advance
+    std::vector<uint8_t>  advY;               // Y index (authored orderlist position) at each advance
+    std::vector<uint16_t> advPc;              // PC of the (zp),Y read at each advance (consuming voice proxy)
+    uint32_t nAdv = 0;                        // number of advance events recorded
+    uint64_t count = 0;                       // total (zp),Y accesses on this pair
+    uint8_t  yMin = 0xff, yMax = 0;           // Y index range across all accesses
+    uint16_t lastPtr = 0;                     // most recent pointer value
+    bool     haveLast = false;
+    bool     isLoad = false;                  // saw a load (0xB1) on this pair
+    bool     isStore = false;                 // saw a store (0x91) on this pair
+};
+
+// --- RELO (init block-copy capture; recovery-offload item #3) --------------
+// During PHASE_INIT a `LDA src,Y / STA dst,Y` (or stride-2 interleaved) copy
+// loop relocates a table to its runtime base. Each init STORE that is an indexed
+// write whose value came from an indexed read is one such copy; we accumulate
+// per init store-PC the (src_base, dst_base, length, src_stride, dst_stride,
+// count). delta = dst_base - src_base is the relocation offset the recovery
+// needs to read image-relative tables. Keyed by the store PC. Mirror of the
+// SID-write filler on the WRITE side, restricted to the init phase.
+struct ReloCopy
+{
+    uint64_t count = 0;       // store iterations seen
+    uint16_t srcBase = 0;     // fitted source base (read side, addr - idx)
+    uint16_t dstBase = 0;     // fitted destination base (write side, addr - idx)
+    int32_t  srcStride = 0;   // source element stride (best effort)
+    int32_t  dstStride = 0;   // destination element stride (best effort)
+    uint8_t  idxMin = 0xff, idxMax = 0;       // copy index span -> length
+    uint16_t srcLastAddr = 0, dstLastAddr = 0;
+    bool     srcSet = false, dstSet = false;
+    uint16_t srcReadPc = 0;   // PC of the feeding indexed read (provenance)
+};
+
+// --- SIDDF (per-write data-flow summary) types ---------------------------
+
+// 6502 register identifiers used by the in-emulator slicer's needed-set.
+enum SliceReg : uint8_t { SR_A = 0, SR_X = 1, SR_Y = 2, SR_NONE = 0xff };
+
+// ALU op kinds recorded on a slice's value-defining chain. These mirror the
+// 6502 ALU the synthesis DSL spans (design 2.5). Loads/stores/transfers are not
+// ALU ops; they carry the value unchanged.
+enum AluOp : uint8_t
+{
+    ALU_NONE = 0,   // load / transfer / store (no arithmetic on the value)
+    ALU_ADC,        // add with carry (+ imm or + mem)
+    ALU_SBC,        // subtract with carry
+    ALU_AND,        // bitwise and
+    ALU_ORA,        // bitwise or
+    ALU_EOR,        // bitwise xor
+    ALU_ASL,        // shift left
+    ALU_LSR,        // shift right
+    ALU_ROL,        // rotate left
+    ALU_ROR,        // rotate right
+    ALU_INC,        // increment (mem or reg INX/INY)
+    ALU_DEC,        // decrement (mem or reg DEX/DEY)
+    ALU_CMP,        // compare (control-edge predicate)
+};
+
+// Leaf classification of a slice leaf (design 3.1 / 2.3).
+enum LeafKind : uint8_t
+{
+    LK_IMMEDIATE = 0,   // an immediate operand byte (a constant K)
+    LK_RAM_READ,        // RAM read as data, not written during play, not exec (song-data K)
+    LK_STATE_CELL,      // EXEC_PLAY & WRITE_PLAY  -> self-modified operand (SMC state)
+                        //  OR  WRITE_PLAY & READ_PLAY in RAM (a persistent zp/ram state cell)
+    LK_EXOGENOUS,       // written during play but owned by another code path / shared counter
+    LK_OUT_OF_WINDOW,   // the def-chain exited the ring buffer (bound may need tuning)
+};
+
+// One leaf of a (PC,reg) slice. Accumulated as a set keyed by (kind, addr/value).
+struct SiddfLeaf
+{
+    uint8_t  kind = LK_OUT_OF_WINDOW;   // LeafKind
+    uint16_t addr = 0;                  // RAM/state/exogenous address (0 for immediate)
+    uint8_t  value = 0;                 // representative value (immediate value, or last seen)
+};
+
+// --- STATESEQ (bounded inter-frame state-cell sample sequence) types -------
+// To run Stage C (Daikon-style inter-frame relation + Berlekamp-Massey) the host
+// needs the SEQUENCE of each candidate state cell across play-calls -- but only
+// for the handful of cells the SIDDF slices flag as state, and bounded to the
+// first M samples per cell (>= 2L for any recoverable linear recurrence; enough
+// for Daikon statistical justification). Per cell we also keep a cheap
+// in-emulator running check that the recurrence implied by the first M samples
+// continues to hold to the end of the capture (holdsToEnd), so the host can
+// trust a short window without re-deriving over the whole run. O(state cells *
+// M), flat vs run length. (design 3.2)
+struct StateSeqCell
+{
+    // FULL-LENGTH (recovery campaign): the inter-frame state sequence must cover
+    // the WHOLE tune (~2270-2300 frames) for the freq/accumulator recovery to be
+    // complete -- the old 512-sample window faked a wall on long tunes. We grow the
+    // sample vector to the tune length, capped only at the u16 nSamples emit-field
+    // ceiling. (The host's holds-to-end check is unaffected; it now sees the full
+    // sequence.)
+    static constexpr uint32_t SS_M = 65535;  // u16 nSamples ceiling (emit field width)
+    std::vector<uint16_t> samples;          // per-play-call samples (u16-wide so a 16-bit pair can be stored if ever needed; cells are u8 in practice)
+    uint32_t nSamples = 0;                  // number of samples actually taken
+    uint32_t totalFrames = 0;              // play-calls seen for this cell
+    uint32_t firstSeenFrame = 0;            // global play-call index of sample[0]
+    bool     wide = false;                  // true if any sample exceeded 0xff
+    // holds_to_end check: once SS_M samples are in, the host-equivalent in-emulator
+    // fold tests whether the simplest single-template recurrence the window
+    // implies (s'=s+c constant first difference, modulo the cell width) keeps
+    // holding. We track it conservatively: the first-difference of the prefix must
+    // remain constant (mod 256) for the running prediction to hold. If the cell is
+    // not a constant-stride accumulator the prefix difference is not constant and
+    // holdsToEnd is reported false (the host then does the full fit from samples).
+    bool     diffKnown = false;
+    int32_t  firstDiff = 0;                 // (samples[1]-samples[0]) mod 256 candidate
+    bool     constDiff = true;              // first-difference constant so far (mod 256)
+    uint16_t lastSample = 0;
+    bool     haveLast = false;
+    uint32_t lastSampledFrame = 0xffffffff;  // frame of the most recent sample
+                                             // (one sample per frame per cell)
+};
+
+// One retired-instruction record in the ring buffer. Assembled from the bus
+// event stream between opcode-fetch boundaries -- addressing-mode-agnostic.
+struct RetiredInstr
+{
+    uint16_t pc = 0;          // instruction start PC (the code site)
+    uint8_t  opcode = 0;      // first fetched byte at pc
+    bool     gotOpcode = false;
+    uint8_t  imm = 0;         // first operand byte (the immediate, for #imm modes)
+    bool     hasImm = false;
+    uint16_t immAddr = 0;     // RAM address of the first operand byte (= pc+1 for
+                              // 2-byte #imm modes). When that byte is itself written
+                              // during play (EXEC&WRITE = SMC) the immediate is NOT a
+                              // constant -- it is a self-modified-operand STATE cell
+                              // (design 1.3 SMC / 2.3), the DefMon compiled-player
+                              // class: `LDX #lo / STX $D4xx` with the `#lo` operand
+                              // poked each call. The slicer must follow it as state.
+    uint16_t fetchLo = 0;     // first instruction-fetch address (= opcode addr)
+    uint32_t fetchCount = 0;  // number of code-fetch bytes consumed this instr
+    uint16_t memAddr = 0;     // effective data address (read or write), if any
+    uint8_t  memVal = 0;      // value transferred at memAddr
+    bool     memRead = false; // saw a data read (non-code, non-SID)
+    bool     memWrite = false;// saw a data write (non-SID)
+    uint16_t idxBase = 0;     // memAddr - index, if an indexed data access
+    uint8_t  idxVal = 0;      // the index register value used
+    uint8_t  idxUsed = SR_NONE; // index reg (X/Y) used for an indexed data access
+    uint8_t  regA = 0, regX = 0, regY = 0;   // register file AFTER retirement
+    uint64_t ringSeq = 0;     // monotone retirement sequence (staleness check)
+    // (zp),Y pointer-pair address: the operand byte of an indirect-indexed access
+    // (the zero-page address of the pointer pair). libsidplayfp reads it via
+    // FetchLowPointer (no recordFetch), so it arrives as the instruction's FIRST
+    // data read (value = the zp address); captured in record() for PWLK (item #2).
+    uint8_t  zpPtr = 0;
+    bool     zpPtrSet = false;
+};
+
+// The accumulated per-(PC,reg) data-flow summary (the SIDDF record).
+struct SiddfSummary
+{
+    uint64_t count = 0;       // number of times this (PC,reg) store retired
+    uint8_t  valLo = 0xff, valHi = 0, valFirst = 0;
+    bool     valSeen = false;
+    // bounded sets (union across all slices of this site; tens of entries)
+    std::vector<uint16_t> slicePcs;     // PCs in the backward slice
+    std::vector<SiddfLeaf> leaves;      // classified leaves
+    std::vector<uint8_t>   opSeq;       // ALU op sequence on the value chain (most-recent->root order; deduped per-slice already short)
+    // strided interval of an indexed read feeding this write (attributed here)
+    bool     hasStride = false;
+    uint16_t strideBase = 0;
+    int32_t  strideStep = 0;
+    uint8_t  strideIdxMin = 0xff;
+    uint8_t  strideIdxMax = 0;
+    bool     anyOutOfWindow = false;
+    // MID-CALL value sequence (SDCU only): the bounded sequence of values the
+    // cell's in-call UPDATE actually wrote, sampled at the update site (NOT at the
+    // call boundary). A fast mid-call SMC cell (A Mind's $14 LFSR) is consumed and
+    // overwritten WITHIN a play-call, so its call-boundary STATESEQ sample is a
+    // constant (the carried-out residue) and tells the host nothing. The value the
+    // update writes IS the generator's state sequence -- the input Berlekamp-Massey
+    // needs to decide LFSR-vs-not. Bounded (SDCU_VALSEQ_M entries), flat vs frames.
+    static constexpr uint32_t SDCU_VALSEQ_M = 512;
+    std::vector<uint8_t> valSeq;        // first SDCU_VALSEQ_M update-written values
+
+    // --- ACCUMULATED tag (recovery-offload item #7) -----------------------
+    // The source shadow cell that feeds this $D4xx write is written >=2x per
+    // play-call by DISTINCT PCs (freq = base (+) vib_acc (+) porta_acc). We
+    // detect this per frame: the set of distinct PCs that wrote the leaf state
+    // cell(s) of this slice WITHIN one play-call. If >=2 distinct PCs touched a
+    // contributing cell in a single call, the write is ACCUMULATED -- the host
+    // must model each addend (op, cell) separately rather than treating the
+    // summed output as free pitch. addends holds the contributing (op-of-the-
+    // writing-instruction, cell-address) pairs. Bounded; deduped.
+    bool     accumulated = false;
+    struct Addend { uint8_t op; uint16_t cell; };
+    std::vector<Addend> addends;     // contributing (op, addend-cell) pairs
+};
+
+class MemBusTrace
+{
+public:
+    bool enabled = false;
+    uint8_t phase = PHASE_BOOT;
+
+    // Ring buffer of retired instructions for the in-emulator backward slicer.
+    // Bounded and FLAT vs run length: it holds at most RING_CAP retired
+    // instructions of the CURRENT play-call, never the whole run. One play-call
+    // can be a few thousand instructions for a busy driver (GoatTracker computes a
+    // SID shadow buffer early in the call and blits it at the end, so a freq
+    // store's backward slice must reach back across the whole call to find the
+    // note-table read that filled the shadow). 4096 covers a full PAL play-call
+    // (~19656 cyc, well under 4096 retired instrs of real work) while peak memory
+    // stays flat: RING_CAP * sizeof(RetiredInstr) ~= 100 KB, independent of N.
+    static constexpr uint32_t RING_CAP = 4096;
+
+    // Getters installed by the c64 object (mirror the existing clock getter).
+    typedef int64_t  (*ClockFn)(void *ctx);
+    typedef uint16_t (*U16Fn)(void *ctx);
+    typedef uint8_t  (*U8Fn)(void *ctx);
+    typedef uint8_t  (*RamFn)(void *ctx, uint16_t addr);
+
+    ClockFn clockFn = nullptr; void *clockCtx = nullptr;
+    U16Fn   pcFn    = nullptr; void *pcCtx    = nullptr;  // issuing instr start PC
+    U8Fn    xFn     = nullptr; void *xCtx     = nullptr;  // X index register
+    U8Fn    yFn     = nullptr; void *yCtx     = nullptr;  // Y index register
+    U8Fn    aFn     = nullptr; void *aCtx     = nullptr;  // A accumulator
+    RamFn   ramFn   = nullptr; void *ramCtx   = nullptr;  // live RAM byte getter
+
+    // --- distilled state (bounded; never grows with run length) ---
+    uint8_t  acc[65536];            // per-address AccBits
+    uint8_t  ramSnapshot[65536];    // post-init RAM image (verbatim song bytes)
+    bool     ramSnapshotTaken = false;
+    int64_t  firstSidWriteCycle = -1;  // anchor hint for the play phase
+
+    // PC-tagged SID writes: key = (pc << 5) | reg(0..31).
+    std::map<uint32_t, SidWrSummary> sidWrites;
+    // Indexed reads keyed by issuing PC.
+    std::map<uint16_t, IdxSummary> idxReads;
+    // Timestamped SID-write stream (small; for the per-frame render gate).
+    std::vector<SidWrEvent> sidStream;
+
+    // SIDDF: per-(PC,reg) data-flow summary, same key space as sidWrites.
+    std::map<uint32_t, SiddfSummary> siddf;
+
+    // SDCU (per-state-cell UPDATE data-flow summary; design 2.2/2.3). For a fast
+    // mid-call SMC accumulator the SID-write slice bottoms out at the state cell
+    // as a LEAF (the blit just copies the shadow cell to the register); the
+    // generator is the STORE that DEFINED that cell earlier in the SAME play-call
+    // (e.g. A Mind's `LDA $f7,X; STA $12`, or the LFSR `SRE $14`). SDCU is the
+    // backward slice of each state cell's in-call defining store -- the update
+    // DAG `cell' = f(cell, C, K, ...)` the host generalizes into U. Keyed by the
+    // cell ADDRESS (a handful of cells), O(state cells) not O(frames). Reuses the
+    // SiddfSummary shape (op_seq + leaves + strided interval + immediates), but the
+    // `reg` field of the record is unused; the key is the cell address. We also
+    // remember which SID register(s) read this cell so the host can attribute the
+    // recovered update to the axis it drives.
+    std::map<uint16_t, SiddfSummary> sdcu;
+
+    // STATESEQ: per-candidate-state-cell inter-frame sample sequence (design 3.2).
+    // Keyed by RAM address. Populated once per play-call (frame) for every address
+    // that, at sampling time, satisfies the state-cell predicate (WRITE_PLAY &
+    // READ_PLAY in RAM, or EXEC_PLAY & WRITE_PLAY -- the SMC-correct state class).
+    // At emit time the section is filtered to the cells SIDDF actually flagged as
+    // state leaves, keeping it to the handful of real state cells. Bounded:
+    // <=STATESEQ_CAP cells * SS_M samples, flat vs run length.
+    static constexpr uint32_t STATESEQ_CAP = 96;
+    std::map<uint16_t, StateSeqCell> stateSeq;
+
+    // PWLK: (zp),Y pointer-walk capture, keyed by zp-pair base (recovery item #2).
+    std::map<uint16_t, PtrWalkCell> ptrWalks;
+    // RELO: init block-copy capture, keyed by init store PC (recovery item #3).
+    std::map<uint16_t, ReloCopy> reloCopies;
+
+    // Per-state-cell accumulation tracking (recovery item #7). Within one
+    // play-call we count the distinct PCs that wrote each state cell; >=2 ->
+    // the cell is an ACCUMULATOR (multiple addends per call). We remember, per
+    // cell, the set of writer PCs seen in the CURRENT frame (reset each frame)
+    // plus the op of each contributing writer, and a sticky flag that the cell
+    // was multiply-written in some frame. Keyed by cell address. Bounded to the
+    // SIDDF state cells (a handful).
+    struct AccumTrack
+    {
+        uint16_t framePcs[4] = {0, 0, 0, 0};  // distinct writer PCs this frame
+        uint8_t  frameOps[4] = {0, 0, 0, 0};  // op of each (parallel to framePcs)
+        uint8_t  nFramePcs = 0;
+        uint32_t lastFrame = 0xffffffff;       // frame the set belongs to
+        bool     multiWritten = false;         // >=2 distinct PCs in some frame
+        uint16_t writerPcs[8] = {0};           // union of contributing PCs (multi frames)
+        uint8_t  writerOps[8] = {0};
+        uint8_t  nWriters = 0;
+    };
+    std::map<uint16_t, AccumTrack> accumTrack;
+    // The DIGI / header-density section (recovery item #4) is computed at emit
+    // time from sidStream + the frame-gap detector; no per-frame state needed
+    // here beyond the burst counters the boundary detector already maintains.
+    // Sub-frame $D418 write tracking for the digi signature: the running count
+    // of $D418 writes in the current play-call burst, and the max over all
+    // bursts. A PCM streamer writes $D418 hundreds of times per frame.
+    uint32_t curFrameD418 = 0;
+    uint32_t maxFrameD418 = 0;
+
+    // RELO init-copy detection (item #3): the most recent INDEXED READ retired
+    // during init -- a `LDA src,Y` whose value the next `STA dst,Y` copies. The
+    // ring buffer is play-phase only, so init copy-loop pairing uses this light
+    // last-read latch (a copy loop is LDA src,Y immediately followed by STA dst,Y).
+    bool     initRdValid = false;
+    uint16_t initRdAddr = 0, initRdPc = 0;
+    uint8_t  initRdIdx = 0, initRdVal = 0;
+    // Frame (play-call) boundary detection: a play-call's SID writes arrive in a
+    // tight burst (~25 writes within a few hundred cycles) separated by a large
+    // inter-call gap (~16k-20k cycles). The first SID write after such a gap marks
+    // a new play-call; that is when we sample the state cells (each cell then holds
+    // the value it carried INTO this call -- the inter-frame state). Threshold is
+    // well below a frame and well above an intra-burst gap.
+    static constexpr int64_t FRAME_GAP_CYCLES = 2000;
+    int64_t  lastSidWriteCycle = -1;
+    bool     anyFrameStarted = false;
+    uint32_t frameNo = 0;          // global play-call index (sampling boundaries)
+
+    // --- ring buffer of retired instructions (bounded backward-slice window) ---
+    RetiredInstr ring[RING_CAP];
+    uint32_t ringHead = 0;     // index of next slot to write
+    uint32_t ringFill = 0;     // number of valid entries (<= RING_CAP)
+    uint64_t ringSeq  = 0;     // monotone count of retired instrs (for staleness)
+
+    // Per-address last-writer index into the ring, with the monotone sequence at
+    // which it was written. Lets the slicer jump to the def of a memory cell that
+    // was last written MANY instructions ago (a persistent state cell updated only
+    // on note-change frames) without scanning -- and without unbounding the ring.
+    // Bounded: two flat 64 KiB-scale arrays, independent of run length. A def is
+    // usable only if still resident in the ring (seq within the last RING_CAP).
+    uint32_t lastWriteSlot[65536];   // ring slot of the most recent writer
+    uint64_t lastWriteSeq[65536];    // ringSeq when that write retired (0 = none)
+
+    // Per-address "filler" summary: the value-defining slice of the LAST store to
+    // this address, captured AT WRITE TIME (when its data-flow context is resident
+    // in the ring). A persistent state cell that a SID-write reads is filled, on a
+    // far-earlier frame, by such a store (e.g. a note-table read into a SID shadow
+    // buffer); caching the filler links the SID-write site to the table read that
+    // ultimately feeds it, WITHOUT keeping the whole run in the ring. Bounded: one
+    // small record per address, flat vs run length. updated=0 means "no filler".
+    struct FillerSlice
+    {
+        uint64_t updated = 0;     // ringSeq+1 at capture (0 = none)
+        bool     hasStride = false;
+        uint16_t strideBase = 0;
+        uint8_t  idxMin = 0xff, idxMax = 0;
+        uint8_t  srcAddrLeafKindProvisional = LK_RAM_READ;
+        uint16_t srcAddr = 0;     // the table/source address the filler dereferenced
+        bool     hasSrcAddr = false;
+        uint8_t  ops[8] = {0};
+        uint8_t  nOps = 0;
+        uint16_t pcs[8] = {0};
+        uint8_t  nPcs = 0;
+    };
+    std::vector<FillerSlice> filler;   // 65536 entries (sized on clear; ~2.6 MB, flat)
+
+    // The instruction currently being assembled from the bus event stream.
+    RetiredInstr cur;
+    bool curValid = false;     // a boundary has begun an instruction
+    // A code fetch is immediately followed by its cpuRead (same address) on the
+    // bus; this pairs them so an operand-byte read is not mistaken for data.
+    uint16_t pendingFetchAddr = 0;
+    bool     pendingFetch = false;
+
+    static MemBusTrace &instance()
+    {
+        static MemBusTrace inst;
+        return inst;
+    }
+
+    inline int64_t  now() const { return clockFn ? clockFn(clockCtx) : 0; }
+    inline uint16_t pc()  const { return pcFn ? pcFn(pcCtx) : 0; }
+    inline uint8_t  xreg()const { return xFn ? xFn(xCtx) : 0; }
+    inline uint8_t  yreg()const { return yFn ? yFn(yCtx) : 0; }
+    inline uint8_t  areg()const { return aFn ? aFn(aCtx) : 0; }
+
+    // A normal data access (read or write) on the bus.
+    inline void record(uint16_t addr, uint8_t val, uint8_t rw)
+    {
+        if (!enabled) return;
+        const bool play = (phase == PHASE_PLAY);
+        if (rw)
+            acc[addr] |= play ? ACC_WRITE_PLAY : ACC_WRITE_INIT;
+        else
+        {
+            acc[addr] |= play ? ACC_READ_PLAY : ACC_READ_INIT;
+            recordIndexedRead(addr);
+        }
+        // A read that pairs with the just-issued code fetch is an opcode/operand
+        // byte, not a data access. The first such operand byte is the immediate /
+        // address-low byte; stash it (used as #imm by the slicer when the opcode
+        // is immediate-mode). All other reads/writes are data the slicer follows.
+        if (curValid && !rw && pendingFetch && addr == pendingFetchAddr)
+        {
+            pendingFetch = false;
+            if (cur.fetchCount == 1)        // opcode byte
+            {
+                cur.opcode = val;
+                cur.gotOpcode = true;
+                return;
+            }
+            if (!cur.hasImm)                // first operand byte
+            {
+                cur.imm = val;
+                cur.immAddr = addr;         // RAM address of the operand byte (SMC check)
+                cur.hasImm = true;
+            }
+            return;
+        }
+        pendingFetch = false;
+
+        // Attribute this data access to the instruction being assembled. The
+        // effective address/value is recorded for ALL accesses (incl. SID-register
+        // stores -- they are the store TARGET the slicer slices on). The slicer
+        // itself never follows a SID-register address as a memory leaf (those
+        // addresses are never added to its needed-memory set), so SID regs are not
+        // mistaken for state. Zero page, RAM, and SMC operands ARE followed.
+        if (curValid)
+        {
+            // (zp),Y / (zp,X) operand capture (PWLK, item #2): libsidplayfp reads
+            // the zp pointer-pair operand byte via FetchLowPointer (NO recordFetch,
+            // so it is not paired as #imm), at PC = opcode_addr + 1. For an
+            // indirect-indexed opcode the read AT THAT ADDRESS is the zp pointer
+            // address; capture it (the first such read only). This does NOT alter
+            // the access map (record() always ran for this read) -- it only stashes
+            // the operand value for the pointer-walk section.
+            if (!rw && !cur.zpPtrSet && cur.gotOpcode &&
+                isIndIndexed(cur.opcode) && addr == (uint16_t)(cur.fetchLo + 1))
+            {
+                cur.zpPtr = val;
+                cur.zpPtrSet = true;
+            }
+            cur.memAddr = addr;
+            cur.memVal  = val;
+            if (rw) cur.memWrite = true; else cur.memRead = true;
+            // Record the index decomposition for indexed reads (the VSA base).
+            const uint8_t x = xreg(), y = yreg();
+            const uint8_t iu = indexRegFor(cur.opcode);
+            if (iu == SR_X && x) { cur.idxUsed = SR_X; cur.idxVal = x; cur.idxBase = (uint16_t)(addr - x); }
+            else if (iu == SR_Y && y) { cur.idxUsed = SR_Y; cur.idxVal = y; cur.idxBase = (uint16_t)(addr - y); }
+        }
+        if (rw && addr >= 0xD400 && addr <= 0xD7FF)
+            recordSidWrite(addr, val);
+    }
+
+    // An instruction opcode/operand fetch (issued by the CPU core).
+    inline void recordFetch(uint16_t addr)
+    {
+        if (!enabled) return;
+        acc[addr] |= (phase == PHASE_PLAY) ? ACC_EXEC_PLAY : ACC_EXEC_INIT;
+        if (curValid)
+        {
+            if (cur.fetchCount == 0) cur.fetchLo = addr;
+            cur.fetchCount++;
+            pendingFetchAddr = addr;
+            pendingFetch = true;
+        }
+    }
+
+    // Called by the CPU core at the start of each opcode fetch (in
+    // fetchNextOpcode), BEFORE the opcode byte is read: the PREVIOUS instruction
+    // has fully retired (the register file now reflects its result), so push it
+    // into the ring buffer, then begin assembling the new instruction. The opcode
+    // and operand bytes are captured from the paired code-fetch reads.
+    inline void beginInstr(uint16_t startPC)
+    {
+        if (!enabled) return;
+        // Retire the previous instruction (if any) into the ring buffer.
+        if (curValid && phase == PHASE_PLAY && cur.gotOpcode)
+        {
+            cur.regA = areg(); cur.regX = xreg(); cur.regY = yreg();
+            ring[ringHead] = cur;
+            const uint32_t retiredIdx = ringHead;
+            cur.ringSeq = ringSeq;
+            ring[ringHead].ringSeq = ringSeq;
+            // Record this instruction as the last writer of its data address (for
+            // cross-window def lookup of persistent state cells). SID registers are
+            // excluded (they are outputs, never followed as state).
+            if (cur.memWrite &&
+                !(cur.memAddr >= 0xD400 && cur.memAddr <= 0xD7FF))
+            {
+                lastWriteSlot[cur.memAddr] = retiredIdx;
+                lastWriteSeq[cur.memAddr]  = ringSeq + 1;   // +1 so 0 means "none"
+                if (isStore(cur.opcode))
+                    captureFiller(cur.memAddr, retiredIdx);
+                // SDCU: if this write targets a candidate state cell (RAM read AND
+                // written during play, or EXEC&WRITE = SMC -- the accumulator /
+                // shadow-cell / self-modified-operand class), slice its update DAG
+                // now (its in-call data-flow context is resident in the ring below
+                // it). Two update kinds: a STA from a computed value (sliced to its
+                // value chain), and an in-place RMW (INC/DEC/shift on memory = the
+                // classic counter/accumulator s' = op(s)). O(state cells), flat vs
+                // frames; a cell that is not actually a state leaf is dropped at
+                // emit time (isSiddfStateCell filter).
+                {
+                    const uint16_t ma = cur.memAddr;
+                    const uint8_t b = acc[ma];
+                    const bool wr = b & ACC_WRITE_PLAY;
+                    const bool rd = b & ACC_READ_PLAY;
+                    const bool ex = b & (ACC_EXEC_INIT | ACC_EXEC_PLAY);
+                    const bool isStateWrite = wr && (rd || ex) &&
+                        !(ma >= 0xD400 && ma <= 0xD7FF);
+                    if (isStateWrite)
+                    {
+                        if (isStore(cur.opcode))
+                            sliceCellUpdate(retiredIdx, ma);
+                        else
+                        {
+                            const uint8_t op = aluOp(cur.opcode);
+                            if (op == ALU_INC || op == ALU_DEC || op == ALU_ASL ||
+                                op == ALU_LSR || op == ALU_ROL || op == ALU_ROR)
+                                recordCellRmw(ma, op, cur.pc);
+                        }
+                        // ACCUMULATED (item #7): track distinct writer PCs of this
+                        // cell within the frame; >=2 -> the cell is an accumulator.
+                        recordAccumWrite(ma, cur.pc, aluOp(cur.opcode));
+                    }
+                }
+            }
+            ringHead = (ringHead + 1) % RING_CAP;
+            if (ringFill < RING_CAP) ringFill++;
+            ringSeq++;
+            // If the just-retired instruction was a STA/STX/STY $D4xx, slice it
+            // now (its full data-flow context is in the ring buffer below it).
+            if (cur.memWrite && cur.memAddr >= 0xD400 && cur.memAddr <= 0xD418)
+                sliceSidWrite(retiredIdx);
+            // PWLK (item #2): a (zp),Y access during play -- the orderlist/pattern
+            // pointer walk. libsidplayfp fetches the zp pointer-pair operand via
+            // FetchLowPointer (no recordFetch), so it is NOT in cur.imm; record()
+            // captures it as the instruction's first data-read VALUE (the operand
+            // byte = the zp address) in cur.zpPtr. Record the live pointer value
+            // sequence + Y span + advance frames (loads 0xB1 + stores 0x91).
+            if (isIndIndexed(cur.opcode) && cur.zpPtrSet &&
+                (cur.memRead || cur.memWrite))
+                recordPtrWalk(cur.zpPtr, cur.idxVal, isStore(cur.opcode), cur.pc);
+        }
+        // RELO (item #3): an init-phase block-copy. The ring buffer is play-only,
+        // so we pair a `LDA src,Y` (latched as the last init indexed read) with the
+        // immediately-following `STA dst,Y` whose stored value matches the read --
+        // the relocation copy loop. delta = dst_base - src_base.
+        else if (curValid && phase == PHASE_INIT && cur.gotOpcode)
+        {
+            const bool isInitStore = isStore(cur.opcode) && cur.memWrite &&
+                cur.idxUsed != SR_NONE &&
+                !(cur.memAddr >= 0xD400 && cur.memAddr <= 0xD7FF);
+            if (isInitStore)
+            {
+                const bool srcMatches = initRdValid && initRdVal == cur.memVal;
+                recordReloCopy(cur.pc, cur.memAddr, cur.idxVal,
+                               srcMatches, initRdAddr, initRdIdx, initRdPc);
+                initRdValid = false;   // consumed
+            }
+            // Latch an indexed READ from RAM (a potential copy source) for the next
+            // store to consume. Only a value-defining indexed read (LDA/LDX/LDY).
+            else if (cur.memRead && cur.idxUsed != SR_NONE &&
+                     defReg(cur.opcode) != SR_NONE && readsMem(cur.opcode) &&
+                     !(cur.memAddr >= 0xD400 && cur.memAddr <= 0xD7FF))
+            {
+                initRdValid = true;
+                initRdAddr = cur.memAddr;
+                initRdIdx = cur.idxVal;
+                initRdVal = cur.memVal;
+                initRdPc = cur.pc;
+            }
+        }
+        cur = RetiredInstr{};
+        cur.pc = startPC;
+        curValid = true;
+        pendingFetch = false;
+    }
+
+    // Capture the live RAM image once, at the init->play boundary.
+    inline void snapshotRam()
+    {
+        if (!ramFn) return;
+        for (uint32_t a = 0; a < 65536; ++a)
+            ramSnapshot[a] = ramFn(ramCtx, (uint16_t)a);
+        ramSnapshotTaken = true;
+    }
+
+    void clear()
+    {
+        std::memset(acc, 0, sizeof(acc));
+        std::memset(ramSnapshot, 0, sizeof(ramSnapshot));
+        ramSnapshotTaken = false;
+        firstSidWriteCycle = -1;
+        sidWrites.clear();
+        idxReads.clear();
+        sidStream.clear();
+        siddf.clear();
+        sdcu.clear();
+        stateSeq.clear();
+        ptrWalks.clear();
+        reloCopies.clear();
+        accumTrack.clear();
+        curFrameD418 = 0;
+        maxFrameD418 = 0;
+        initRdValid = false;
+        initRdAddr = initRdPc = 0;
+        initRdIdx = initRdVal = 0;
+        lastSidWriteCycle = -1;
+        anyFrameStarted = false;
+        frameNo = 0;
+        ringHead = 0;
+        ringFill = 0;
+        ringSeq = 0;
+        std::memset(lastWriteSlot, 0, sizeof(lastWriteSlot));
+        std::memset(lastWriteSeq, 0, sizeof(lastWriteSeq));
+        filler.assign(65536, FillerSlice{});
+        curValid = false;
+        cur = RetiredInstr{};
+        pendingFetch = false;
+    }
+
+private:
+    inline void recordSidWrite(uint16_t addr, uint8_t val)
+    {
+        if (firstSidWriteCycle < 0 && phase == PHASE_PLAY)
+            firstSidWriteCycle = now();
+        // Play-call (frame) boundary: the first SID write of a new burst. Sample
+        // the candidate state cells HERE -- each cell still holds the value it
+        // carried INTO this play-call (the inter-frame state Stage C fits).
+        if (phase == PHASE_PLAY)
+        {
+            const int64_t t = now();
+            if (!anyFrameStarted ||
+                (lastSidWriteCycle >= 0 && (t - lastSidWriteCycle) > FRAME_GAP_CYCLES))
+            {
+                sampleStateCells();
+                anyFrameStarted = true;
+                // DIGI density (item #4): the prior frame's $D418 burst is done;
+                // fold it into the max and reset. A PCM streamer writes $D418
+                // hundreds of times per frame (sub-frame sample playback).
+                if (curFrameD418 > maxFrameD418) maxFrameD418 = curFrameD418;
+                curFrameD418 = 0;
+            }
+            lastSidWriteCycle = t;
+            if ((addr & 0x1f) == 0x18) curFrameD418++;
+        }
+        const uint8_t reg = (uint8_t)(addr & 0x1f);
+        SidWrSummary &s = sidWrites[((uint32_t)pc() << 5) | reg];
+        s.count++;
+        s.lastVal = val;
+        sidStream.push_back(SidWrEvent{ now(), addr, reg, val });
+    }
+
+    inline void recordIndexedRead(uint16_t addr)
+    {
+        // Only summarise reads issued during play (the table walks of interest)
+        // that came through an index register. We key by issuing PC and fold
+        // base = addr - index, tracking the index span and a stride guess.
+        if (phase != PHASE_PLAY) return;
+        const uint8_t x = xreg(), y = yreg();
+        // EXISTING IDXR fields use the legacy dominant index max(x,y) UNCHANGED
+        // (byte-identical to the pre-change emitter; the scaled-index correction
+        // is carried separately in the IDXS supplement, never here).
+        const uint8_t idx = x >= y ? x : y;   // dominant index; best effort
+        if (idx == 0)
+            return;  // non-indexed (or index 0) -- not a table traversal signal
+        const uint16_t p = pc();
+        IdxSummary &s = idxReads[p];
+        const uint16_t base = (uint16_t)(addr - idx);
+        if (!s.baseSet) { s.base = base; s.baseSet = true; }
+        if (s.count)
+        {
+            const int32_t d = (int32_t)addr - (int32_t)s.lastAddr;
+            if (d != 0 && (s.strideGuess == 0 ||
+                           (d > 0 && d < s.strideGuess)))
+                s.strideGuess = d;  // smallest positive step ~ element stride
+        }
+        s.lastAddr = addr;
+        if (idx < s.idxMin) s.idxMin = idx;
+        if (idx > s.idxMax) s.idxMax = idx;
+        s.count++;
+        // SCALED-INDEX samples (item #1): record up to two DISTINCT-index
+        // (idxVal, effAddr) samples USING THE OPCODE'S ACTUAL INDEX REGISTER, so
+        // finalizeOffload can fit scale=(a1-a0)/(i1-i0), base=a0-scale*i0. This
+        // recovers the true base+stride of an interleaved stride-2 (note*2) table
+        // the single-sample base=addr-idx cannot. Kept OUT of the existing fields
+        // above (which stay byte-identical); emitted only in the IDXS section.
+        //
+        // RESTRICT samples to DIRECT (abs/zp),X|Y modes where addr = base +
+        // index_reg is genuinely affine. Indirect (zp),Y reads are addr = ptr + Y
+        // with ptr varying (NOT affine -- those are the PWLK pointer walks), and
+        // would pollute the fit with scale 0/-1.
+        //
+        // CRUCIALLY: recordIndexedRead runs for EVERY read BEFORE the operand-fetch
+        // pairing in record(), so an instruction's own operand-byte reads (at
+        // PC+1/PC+2) reach here with a stale index. Skip those -- a read that pairs
+        // with the just-issued code fetch is an opcode/operand byte, not the
+        // effective indexed data read. (The existing fields above tolerate this
+        // noise and stay byte-identical; only the affine samples must be clean.)
+        if (pendingFetch && addr == pendingFetchAddr) return;
+        if (!(curValid && cur.gotOpcode && isDirectIndexed(cur.opcode)))
+            return;
+        const uint8_t diu = indexRegFor(cur.opcode);
+        const uint8_t sidx = (diu == SR_X) ? x : (diu == SR_Y) ? y : 0;
+        if (sidx == 0) return;   // no meaningful index for the affine sample
+        if (s.nSamp == 0)
+        {
+            s.sampIdx[0] = sidx; s.sampAddr[0] = addr; s.nSamp = 1;
+        }
+        else if (s.nSamp == 1 && sidx != s.sampIdx[0])
+        {
+            s.sampIdx[1] = sidx; s.sampAddr[1] = addr; s.nSamp = 2;
+        }
+        // IWLK per-frame walk-index: record ONE (frame, index) sample per frame
+        // for this direct-indexed read -- the last qualifying read of the frame
+        // wins (the play-call's final table walk = the value driving the SID
+        // write this frame). Bounded: one u8 per frame per IDXR PC. The emit
+        // filter keeps only freq-feeding PCs, so this stays a handful of small
+        // vectors. lastIdxFrame de-dups within a frame.
+        if (s.lastIdxFrame == frameNo && !s.idxFrameSamples.empty())
+            s.idxFrameSamples.back().second = sidx;  // overwrite: last read wins
+        else if (s.idxFrameSamples.size() < StateSeqCell::SS_M)
+        {
+            s.idxFrameSamples.emplace_back(frameNo, sidx);
+            s.lastIdxFrame = frameNo;
+        }
+    }
+
+    // Is the opcode an indirect-indexed (zp),Y access (the orderlist/pattern
+    // pointer-walk idiom)? 0xB1 = LDA (zp),Y; 0x91 = STA (zp),Y; plus the illegal
+    // LAX (zp),Y 0xB3. The operand byte is the zero-page pointer-pair address.
+    static inline bool isIndIndexed(uint8_t op)
+    {
+        return op == 0xB1 || op == 0x91 || op == 0xB3;
+    }
+
+    // Is the opcode a DIRECT indexed read whose effective address is genuinely
+    // base + index_register (absolute,X|Y or zp,X|Y) -- as opposed to indirect
+    // (zp),Y/(zp,X) where the address is ptr+index with a VARYING pointer? Only
+    // the direct forms yield a clean affine (idx -> addr) sample for the IDXR
+    // scale fit; the indirect forms are pointer walks (PWLK). Reads only (the
+    // value-defining loads / ALU-with-memory we care to attribute as tables).
+    static inline bool isDirectIndexed(uint8_t op)
+    {
+        const uint8_t iu = indexRegFor(op);
+        if (iu == SR_NONE) return false;
+        if (isIndIndexed(op)) return false;          // (zp),Y / LAX (zp),Y
+        switch (op)
+        {
+        // (zp,X) pre-indexed indirect forms -- also pointer-based, not affine.
+        case 0xA1: case 0xC1: case 0xE1: case 0x21: case 0x41: case 0x61:
+        case 0x01: case 0x81:
+            return false;
+        }
+        return true;   // abs,X | abs,Y | zp,X | zp,Y
+    }
+
+    // PWLK (item #2): record a (zp),Y access. `zp` is the zero-page pointer-pair
+    // address (the operand byte); the live pointer value is ram(zp)|ram(zp+1)<<8;
+    // `y` is the index. We dedup consecutive-equal pointer values into ADVANCE
+    // events (a new pointer = the orderlist advanced to a new pattern) and record
+    // the frame index of each advance (the row/note onset). FULL-LENGTH: the whole
+    // advance schedule is kept (growable), capped only at the u16 emit-field
+    // ceiling, so the recovery sees the entire orderlist->pattern schedule (not the
+    // first 256 advances).
+    inline void recordPtrWalk(uint16_t zp, uint8_t y, bool isStore, uint16_t pc)
+    {
+        if (!ramFn) return;
+        const uint16_t ptr = (uint16_t)(ramFn(ramCtx, zp) |
+                                        (ramFn(ramCtx, (uint16_t)(zp + 1)) << 8));
+        PtrWalkCell &c = ptrWalks[zp];
+        c.count++;
+        if (isStore) c.isStore = true; else c.isLoad = true;
+        if (y < c.yMin) c.yMin = y;
+        if (y > c.yMax) c.yMax = y;
+        if (!c.haveLast || ptr != c.lastPtr)
+        {
+            if (c.nAdv < PtrWalkCell::PW_CAP)
+            {
+                c.ptrVals.push_back(ptr);
+                c.advFrame.push_back(frameNo);
+                // The Y index is the authored orderlist POSITION of this advance; the
+                // (zp),Y read PC distinguishes the consuming voice (each voice reads the
+                // shared orderlist at its own play-routine PC). Together they let the
+                // recovery collapse the per-voice/per-row read stream back to the single
+                // authored orderlist (the Y-walk) + its loop point (where Y wraps).
+                c.advY.push_back(y);
+                c.advPc.push_back(pc);
+                c.nAdv++;
+            }
+            c.lastPtr = ptr;
+            c.haveLast = true;
+        }
+    }
+
+    // ACCUMULATED tracking (item #7): note that `pc` (op `op`) wrote state cell
+    // `cellAddr` during the current play-call. If >=2 DISTINCT PCs write the same
+    // cell within one frame, the cell is an accumulator (multiple addends per
+    // call, e.g. freq = base + vib_acc + porta_acc). We keep a per-frame distinct-
+    // PC set per cell; on crossing >=2 we set multiWritten and union the
+    // contributing (pc, op) into the writer list the host reports.
+    inline void recordAccumWrite(uint16_t cellAddr, uint16_t pc, uint8_t op)
+    {
+        AccumTrack &a = accumTrack[cellAddr];
+        if (a.lastFrame != frameNo)
+        {
+            a.lastFrame = frameNo;
+            a.nFramePcs = 0;
+        }
+        bool seen = false;
+        for (uint8_t i = 0; i < a.nFramePcs; ++i)
+            if (a.framePcs[i] == pc) { seen = true; break; }
+        if (!seen && a.nFramePcs < 4)
+        {
+            a.framePcs[a.nFramePcs] = pc;
+            a.frameOps[a.nFramePcs] = op;
+            a.nFramePcs++;
+        }
+        if (a.nFramePcs >= 2)
+        {
+            a.multiWritten = true;
+            // union the frame's writers into the reported contributor list
+            for (uint8_t i = 0; i < a.nFramePcs; ++i)
+            {
+                bool have = false;
+                for (uint8_t j = 0; j < a.nWriters; ++j)
+                    if (a.writerPcs[j] == a.framePcs[i]) { have = true; break; }
+                if (!have && a.nWriters < 8)
+                {
+                    a.writerPcs[a.nWriters] = a.framePcs[i];
+                    a.writerOps[a.nWriters] = a.frameOps[i];
+                    a.nWriters++;
+                }
+            }
+        }
+    }
+
+    // RELO (item #3): record one iteration of an init block-copy store. `dst` is
+    // the store's effective address and `dstIdx` its index; the feeding indexed
+    // read supplies `src`/`srcIdx`. We fold per store-PC the src/dst bases
+    // (addr - idx), strides (smallest positive inter-iteration delta), and index
+    // span (-> length). delta = dst_base - src_base. Init phase only.
+    inline void recordReloCopy(uint16_t storePc, uint16_t dst, uint8_t dstIdx,
+                               bool haveSrc, uint16_t src, uint8_t srcIdx,
+                               uint16_t srcPc)
+    {
+        ReloCopy &r = reloCopies[storePc];
+        r.count++;
+        if (haveSrc)
+        {
+            const uint16_t sb = (uint16_t)(src - srcIdx);
+            if (!r.srcSet) { r.srcBase = sb; r.srcSet = true; r.srcReadPc = srcPc; }
+            if (r.count > 1)
+            {
+                const int32_t d = (int32_t)src - (int32_t)r.srcLastAddr;
+                if (d != 0 && (r.srcStride == 0 || (d > 0 && d < r.srcStride)))
+                    r.srcStride = d;
+            }
+            r.srcLastAddr = src;
+        }
+        const uint16_t db = (uint16_t)(dst - dstIdx);
+        if (!r.dstSet) { r.dstBase = db; r.dstSet = true; }
+        if (r.count > 1)
+        {
+            const int32_t d = (int32_t)dst - (int32_t)r.dstLastAddr;
+            if (d != 0 && (r.dstStride == 0 || (d > 0 && d < r.dstStride)))
+                r.dstStride = d;
+        }
+        r.dstLastAddr = dst;
+        if (dstIdx < r.idxMin) r.idxMin = dstIdx;
+        if (dstIdx > r.idxMax) r.idxMax = dstIdx;
+    }
+
+    // ----- 6502 opcode semantics for the slicer (def/use/ALU classification) ---
+    // These are HARDWARE facts about the 6502 ISA (which register an opcode
+    // defines, which it uses, what ALU op it performs, whether it reads memory)
+    // -- NOT any tracker/player format knowledge. Illegal/undocumented opcodes
+    // that A Mind uses are handled by the common families below; anything not
+    // recognised contributes no edge (the slice records it as a PC but follows no
+    // operand, which the residual gate will surface if it matters).
+
+    // Which register (if any) the opcode DEFINES (writes its result to).
+    static inline uint8_t defReg(uint8_t op)
+    {
+        switch (op)
+        {
+        // loads / arithmetic / logic into A
+        case 0xA9: case 0xA5: case 0xB5: case 0xAD: case 0xBD: case 0xB9:
+        case 0xA1: case 0xB1:                                   // LDA
+        case 0x69: case 0x65: case 0x75: case 0x6D: case 0x7D: case 0x79:
+        case 0x61: case 0x71:                                   // ADC
+        case 0xE9: case 0xE5: case 0xF5: case 0xED: case 0xFD: case 0xF9:
+        case 0xE1: case 0xF1:                                   // SBC
+        case 0x29: case 0x25: case 0x35: case 0x2D: case 0x3D: case 0x39:
+        case 0x21: case 0x31:                                   // AND
+        case 0x09: case 0x05: case 0x15: case 0x0D: case 0x1D: case 0x19:
+        case 0x01: case 0x11:                                   // ORA
+        case 0x49: case 0x45: case 0x55: case 0x4D: case 0x5D: case 0x59:
+        case 0x41: case 0x51:                                   // EOR
+        case 0x0A:                                              // ASL A
+        case 0x4A:                                              // LSR A
+        case 0x2A:                                              // ROL A
+        case 0x6A:                                              // ROR A
+        case 0x8A:                                              // TXA
+        case 0x98:                                              // TYA
+        case 0x68:                                              // PLA
+            return SR_A;
+        }
+        // Illegal/undocumented opcodes that load A (A Mind Is Born relies on
+        // these; the emulator already runs them, so the slice must follow them).
+        switch (op)
+        {
+        case 0xAB:                                             // LAX # (ATX/LXA)
+        case 0xA7: case 0xB7: case 0xAF: case 0xBF: case 0xA3: case 0xB3: // LAX
+        case 0x4B:                                             // ALR  (AND+LSR -> A)
+        case 0x0B: case 0x2B:                                 // ANC  -> A
+        case 0x6B:                                             // ARR  -> A
+        case 0xEB:                                             // SBC# (illegal alias)
+            return SR_A;   // (LAX also loads X; handled as a secondary def below)
+        }
+        switch (op)
+        {
+        case 0xA2: case 0xA6: case 0xB6: case 0xAE: case 0xBE:  // LDX
+        case 0xAA:                                              // TAX
+        case 0xE8:                                              // INX
+        case 0xCA:                                              // DEX
+        case 0xBA:                                              // TSX
+        case 0xCB:                                             // AXS/SBX -> X
+            return SR_X;
+        case 0xA0: case 0xA4: case 0xB4: case 0xAC: case 0xBC:  // LDY
+        case 0xA8:                                              // TAY
+        case 0xC8:                                              // INY
+        case 0x88:                                              // DEY
+            return SR_Y;
+        }
+        return SR_NONE;
+    }
+
+    // Does the opcode ALSO define X (LAX loads A and X together)?
+    static inline bool alsoDefsX(uint8_t op)
+    {
+        switch (op)
+        {
+        case 0xAB: case 0xA7: case 0xB7: case 0xAF: case 0xBF:
+        case 0xA3: case 0xB3:
+            return true;
+        }
+        return false;
+    }
+
+    // The ALU op the opcode performs on the value chain (ALU_NONE for plain
+    // load/store/transfer).
+    static inline uint8_t aluOp(uint8_t op)
+    {
+        switch (op)
+        {
+        case 0x69: case 0x65: case 0x75: case 0x6D: case 0x7D: case 0x79:
+        case 0x61: case 0x71: return ALU_ADC;
+        case 0xE9: case 0xE5: case 0xF5: case 0xED: case 0xFD: case 0xF9:
+        case 0xE1: case 0xF1: return ALU_SBC;
+        case 0x29: case 0x25: case 0x35: case 0x2D: case 0x3D: case 0x39:
+        case 0x21: case 0x31: return ALU_AND;
+        case 0x09: case 0x05: case 0x15: case 0x0D: case 0x1D: case 0x19:
+        case 0x01: case 0x11: return ALU_ORA;
+        case 0x49: case 0x45: case 0x55: case 0x4D: case 0x5D: case 0x59:
+        case 0x41: case 0x51: return ALU_EOR;
+        case 0x0A: case 0x06: case 0x16: case 0x0E: case 0x1E: return ALU_ASL;
+        case 0x4A: case 0x46: case 0x56: case 0x4E: case 0x5E: return ALU_LSR;
+        case 0x2A: case 0x26: case 0x36: case 0x2E: case 0x3E: return ALU_ROL;
+        case 0x6A: case 0x66: case 0x76: case 0x6E: case 0x7E: return ALU_ROR;
+        case 0xE6: case 0xF6: case 0xEE: case 0xFE: case 0xE8: case 0xC8:
+            return ALU_INC;
+        case 0xC6: case 0xD6: case 0xCE: case 0xDE: case 0xCA: case 0x88:
+            return ALU_DEC;
+        case 0xC9: case 0xC5: case 0xD5: case 0xCD: case 0xDD: case 0xD9:
+        case 0xC1: case 0xD1:                                   // CMP
+        case 0xE0: case 0xE4: case 0xEC:                        // CPX
+        case 0xC0: case 0xC4: case 0xCC:                        // CPY
+            return ALU_CMP;
+        }
+        return ALU_NONE;
+    }
+
+    // Does the opcode take a second source operand from MEMORY (so the slicer
+    // must follow the loaded address) as opposed to an immediate / register-only?
+    static inline bool readsMem(uint8_t op)
+    {
+        switch (op)
+        {
+        // immediate-mode (operand is a constant, no memory source)
+        case 0xA9: case 0xA2: case 0xA0:                        // LDA/X/Y #
+        case 0x69: case 0xE9: case 0x29: case 0x09: case 0x49:  // ADC/SBC/AND/ORA/EOR #
+        case 0xC9: case 0xE0: case 0xC0:                        // CMP/CPX/CPY #
+        case 0x0A: case 0x4A: case 0x2A: case 0x6A:             // shifts on A
+        case 0x8A: case 0x98: case 0xAA: case 0xA8: case 0xBA:  // transfers
+        case 0xE8: case 0xCA: case 0xC8: case 0x88:             // INX/DEX/INY/DEY
+        case 0x68:                                              // PLA
+        case 0xAB: case 0x4B: case 0x0B: case 0x2B: case 0x6B:  // LAX#/ALR/ANC/ARR (imm)
+        case 0xCB:                                              // AXS/SBX #
+            return false;
+        }
+        return true;   // any other recognised value-defining op reads memory
+    }
+
+    // Which index register an opcode's effective address uses (indexed modes).
+    static inline uint8_t indexRegFor(uint8_t op)
+    {
+        switch (op)
+        {
+        case 0xBD: case 0x7D: case 0xFD: case 0x3D: case 0x1D: case 0x5D: // ,X abs
+        case 0xB5: case 0x75: case 0xF5: case 0x35: case 0x15: case 0x55: // ,X zp
+        case 0xBC: case 0xDE: case 0xFE: case 0x1E: case 0x3E: case 0x5E:
+        case 0x7E: case 0x9D: case 0xD6: case 0xF6: case 0x16: case 0x36:
+        case 0x56: case 0x76: case 0x95: case 0xB6: /* LDX zp,Y handled below */
+        case 0xA1: case 0xC1: case 0xE1: case 0x21: case 0x41: case 0x61:
+        case 0x01: case 0x81:                                   // (zp,X)
+            return SR_X;
+        case 0xB9: case 0x79: case 0xF9: case 0x39: case 0x19: case 0x59: // ,Y abs
+        case 0xBE: case 0x99: case 0xD9:                        // ,Y
+        case 0xB1: case 0xD1: case 0xF1: case 0x31: case 0x11: case 0x51:
+        case 0x71: case 0x91:                                   // (zp),Y
+        case 0xB7: case 0xBF: case 0xB3:                        // LAX zp,Y / abs,Y / (zp),Y
+            return SR_Y;
+        }
+        // LDX abs,Y (0xBE), LDX zp,Y (0xB6) already mapped; default none.
+        switch (op) { case 0xB6: case 0xBE: return SR_Y; }
+        return SR_NONE;
+    }
+
+    // The source register of a store (STA/STX/STY).
+    static inline uint8_t storeSrcReg(uint8_t op)
+    {
+        switch (op)
+        {
+        case 0x85: case 0x95: case 0x8D: case 0x9D: case 0x99:
+        case 0x81: case 0x91: return SR_A;                      // STA
+        case 0x86: case 0x96: case 0x8E: return SR_X;           // STX
+        case 0x84: case 0x94: case 0x8C: return SR_Y;           // STY
+        }
+        return SR_A;   // default (covers SAX-style illegal stores -> A&X, treat A)
+    }
+
+    static inline bool isStore(uint8_t op)
+    {
+        switch (op)
+        {
+        case 0x85: case 0x95: case 0x8D: case 0x9D: case 0x99:
+        case 0x81: case 0x91:                                   // STA
+        case 0x86: case 0x96: case 0x8E:                        // STX
+        case 0x84: case 0x94: case 0x8C:                        // STY
+            return true;
+        }
+        return false;
+    }
+
+    // Classify a leaf address against the access-type map (design 2.3 / 3.1).
+    inline uint8_t classifyLeaf(uint16_t addr) const
+    {
+        const uint8_t b = acc[addr];
+        const bool execAny  = b & (ACC_EXEC_INIT | ACC_EXEC_PLAY);
+        const bool writePlay = b & ACC_WRITE_PLAY;
+        const bool readPlay  = b & ACC_READ_PLAY;
+        // SMC: executed AND written during play -> a self-modified operand byte,
+        // mutable STATE (not constant, not plain data). This is the case the model
+        // requires be classified as state_cell, never as a constant.
+        if (execAny && writePlay) return LK_STATE_CELL;
+        // A RAM cell written during play and also read as data during play is a
+        // persistent state cell (zp accumulator / cursor / counter).
+        if (writePlay && readPlay && addr < 0xd000) return LK_STATE_CELL;
+        // Written during play but not read back here as our own state: an
+        // exogenous source owned by another path (e.g. a shared counter cell).
+        if (writePlay) return LK_EXOGENOUS;
+        // Read as data during play, never written, never executed: a constant /
+        // song-data table byte (K).
+        if (readPlay && !execAny) return LK_RAM_READ;
+        return LK_RAM_READ;
+    }
+
+    // Is `addr` a candidate self-modified-operand byte: fetched as code AND written
+    // at some point (design 1.3 SMC / 2.3)? Such a byte is mutable STATE, not a
+    // constant -- the DefMon compiled-player class (`LDX #lo / STX $D4xx`, the `#lo`
+    // operand poked each call) generates EVERY axis this way, so the immediate the
+    // slicer bottoms out at is really a state cell at the operand address. We accept
+    // EXEC & (WRITE_PLAY | WRITE_INIT) as a CANDIDATE here because the slice's first
+    // walk runs on the first play-call, BEFORE the per-frame writer has set
+    // WRITE_PLAY -- so requiring WRITE_PLAY at walk time misses it. The leaf is
+    // recorded provisionally and finalizeLeaves() makes the SMC-correct call against
+    // the FINAL access-type map (a byte written only during INIT stays a non-state
+    // RAM/immediate constant; a per-call-poked operand becomes LK_STATE_CELL).
+    inline bool isSmcOperandCandidate(uint16_t addr) const
+    {
+        const uint8_t b = acc[addr];
+        return (b & (ACC_EXEC_INIT | ACC_EXEC_PLAY)) &&
+               (b & (ACC_WRITE_PLAY | ACC_WRITE_INIT));
+    }
+
+    // Sample the SIDDF-flagged state cells at a play-call boundary (design 3.2).
+    // We target EXACTLY the cells the live SIDDF slices have already surfaced as
+    // state leaves -- not every write/read RAM cell (a busy player touches
+    // thousands of scratch cells that are written+read during play but carry no
+    // axis state). The SIDDF slicer runs per SID write, so by the time the first
+    // play-call has issued its SID-write burst the relevant state leaves are
+    // populated; a cell that first appears as a state leaf later is picked up at
+    // its first subsequent frame boundary. Bounded: <= STATESEQ_CAP distinct cells
+    // (the slices surface only a handful), SS_M samples each, flat vs run length.
+    inline void sampleStateCells()
+    {
+        if (!ramFn) return;
+        auto sampleCell = [&](uint16_t a) {
+            auto it = stateSeq.find(a);
+            if (it == stateSeq.end())
+            {
+                if (stateSeq.size() >= STATESEQ_CAP) return;   // bounded
+                it = stateSeq.emplace(a, StateSeqCell{}).first;
+            }
+            StateSeqCell &c = it->second;
+            // ONE sample per play-call (frame): a cell that appears in several
+            // SIDDF leaves would otherwise be sampled once per leaf each frame,
+            // replicating the value N x and de-aligning the sequence from the frame
+            // grid the host renders against (this was masked by the old 512 cap;
+            // full-length capture exposes it). Guard on the frame index so each
+            // cell contributes exactly one sample per frame.
+            if (c.lastSampledFrame == frameNo) return;
+            if (c.totalFrames == 0) c.firstSeenFrame = frameNo;
+            const uint8_t v = ramFn(ramCtx, a);
+            c.lastSampledFrame = frameNo;
+            c.totalFrames++;
+            // running constant-first-difference (mod 256) holds-to-end check
+            if (c.haveLast)
+            {
+                const int32_t d = ((int32_t)v - (int32_t)c.lastSample) & 0xff;
+                if (!c.diffKnown) { c.firstDiff = d; c.diffKnown = true; }
+                else if (d != c.firstDiff) c.constDiff = false;
+            }
+            c.lastSample = v;
+            c.haveLast = true;
+            if (c.nSamples < StateSeqCell::SS_M)
+            {
+                c.samples.push_back(v);
+                c.nSamples++;
+            }
+        };
+        // Sample the memory-leaf addresses the live SIDDF slices have surfaced
+        // that ALSO satisfy the state-cell access predicate (the same predicate
+        // classifyLeaf/finalizeLeaves use for LK_STATE_CELL). During the run leaf
+        // kinds are still provisional (reclassified to LK_STATE_CELL only at
+        // finalizeLeaves), so we cannot filter on l.kind here; instead we restrict
+        // to the SIDDF leaf addresses (a handful -- the slices already isolated the
+        // generator's inputs) and apply the access-type predicate directly. This
+        // targets exactly the cells that will be state cells, without scanning the
+        // thousands of scratch RAM cells a busy player also writes+reads. The emit
+        // filter (isSiddfStateCell, after finalizeLeaves) drops any that did not
+        // end up classified as state. Cheap: tens of sites x tens of leaves.
+        for (const auto &kv : siddf)
+            for (const auto &l : kv.second.leaves)
+            {
+                const uint16_t a = l.addr;
+                if (a == 0 || a >= 0xd000) continue;        // skip immediates / IO
+                const uint8_t b = acc[a];
+                const bool execAny   = b & (ACC_EXEC_INIT | ACC_EXEC_PLAY);
+                const bool writePlay = b & ACC_WRITE_PLAY;
+                const bool readPlay  = b & ACC_READ_PLAY;
+                const bool isState = (execAny && writePlay) ||
+                                     (writePlay && readPlay);
+                if (isState) sampleCell(a);
+            }
+        frameNo++;
+    }
+
+    inline RetiredInstr &ringAt(uint32_t i) { return ring[i % RING_CAP]; }
+
+    // Add a PC to a slice's PC set (bounded; dedup).
+    static inline void addPc(SiddfSummary &s, uint16_t p)
+    {
+        if (s.slicePcs.size() >= 64) return;
+        for (uint16_t q : s.slicePcs) if (q == p) return;
+        s.slicePcs.push_back(p);
+    }
+    static inline void addLeaf(SiddfSummary &s, uint8_t kind, uint16_t addr, uint8_t val)
+    {
+        if (kind == LK_OUT_OF_WINDOW) s.anyOutOfWindow = true;
+        if (s.leaves.size() >= 64) return;
+        for (const auto &l : s.leaves)
+            if (l.kind == kind && l.addr == addr) return;
+        s.leaves.push_back(SiddfLeaf{ kind, addr, val });
+    }
+
+    // Capture the value-defining slice of a just-retired STORE to `addr` (slot
+    // `slot`), so a later SID-write whose persistent state cell is `addr` can be
+    // linked to the table read / arithmetic that filled it. A short bounded local
+    // backward scan from `slot` resolving the source register; records the indexed
+    // read's strided interval + source address and the value ALU op sequence.
+    inline void captureFiller(uint16_t addr, uint32_t slot)
+    {
+        if (filler.empty()) return;
+        const RetiredInstr &stw = ring[slot];
+        uint8_t needR = storeSrcReg(stw.opcode);
+        FillerSlice fs;
+        fs.updated = ringSeq + 1;
+        const uint32_t windowLen = ringFill < RING_CAP ? ringFill : RING_CAP;
+        uint32_t idx = slot;
+        bool needReg = true;
+        for (uint32_t steps = 0; steps < windowLen && (needReg) && fs.nPcs < 8; ++steps)
+        {
+            idx = (idx == 0) ? (RING_CAP - 1) : (idx - 1);
+            const RetiredInstr &in = ring[idx];
+            const uint8_t dr = defReg(in.opcode);
+            const bool defs = (dr == needR) || (needR == SR_X && alsoDefsX(in.opcode));
+            if (!defs) continue;
+            if (fs.nPcs < 8) fs.pcs[fs.nPcs++] = in.pc;
+            const uint8_t a = aluOp(in.opcode);
+            if (dr == SR_A && a != ALU_NONE && fs.nOps < 8) fs.ops[fs.nOps++] = a;
+            if (readsMem(in.opcode) && (in.memRead || in.memWrite))
+            {
+                if (in.idxUsed != SR_NONE)
+                {
+                    fs.hasStride = true; fs.strideBase = in.idxBase;
+                    if (in.idxVal < fs.idxMin) fs.idxMin = in.idxVal;
+                    if (in.idxVal > fs.idxMax) fs.idxMax = in.idxVal;
+                }
+                fs.hasSrcAddr = true; fs.srcAddr = in.memAddr;
+                needReg = false;   // reached the load (the source) -> stop
+            }
+            else
+            {
+                // transfer chains: keep chasing the carried register
+                switch (in.opcode)
+                {
+                case 0x8A: needR = SR_X; break;
+                case 0x98: needR = SR_Y; break;
+                case 0xAA: case 0xA8: needR = SR_A; break;
+                default: needReg = false; break;   // immediate/shift -> done
+                }
+            }
+        }
+        filler[addr] = fs;
+    }
+
+    // A work item for the slicer: resolve register `reg` (or a memory address)
+    // as it stood JUST BEFORE ring slot `anchor` (i.e. scan strictly earlier).
+    struct SliceTask { uint32_t anchor; uint8_t reg; uint16_t mem; bool isReg; };
+
+    // ----- SDCU: slice a state cell's in-call UPDATE store (design 2.2/2.3) ----
+    // `storeSlot` is the ring slot of a just-retired STA/STX/STY to `cellAddr` (a
+    // candidate state cell). Build the backward dynamic slice of the STORED VALUE
+    // within this play-call -- the update DAG `cell' = f(cell, C, K, immediates)`
+    // -- and accumulate it into sdcu[cellAddr] (same SiddfSummary shape as a SID
+    // write slice: op_seq + leaves + strided interval + immediates). Bounded; the
+    // shape is invariant across frames so the full walk runs only for the first
+    // few occurrences. This captures EXACTLY what the SID-write slice could not:
+    // how the SMC operand cell is recomputed each call.
+    // Record an in-place RMW update of a state cell (INC/DEC/shift on memory) as a
+    // self-feedback recurrence: cell' = op(cell). The cell is its own leaf (the
+    // prior value carries between calls), and the op is the recurrence kind. This
+    // is the canonical counter/accumulator (s' = s +/- 1) and the LFSR shift cell.
+    inline void recordCellRmw(uint16_t cellAddr, uint8_t op, uint16_t pc)
+    {
+        SiddfSummary &s = sdcu[cellAddr];
+        s.count++;
+        addPc(s, pc);
+        // mid-call value sequence: the cell's value AFTER this RMW retired (the
+        // self-feedback recurrence's next state); bounded, flat vs frames.
+        if (s.valSeq.size() < SiddfSummary::SDCU_VALSEQ_M && ramFn)
+            s.valSeq.push_back(ramFn(ramCtx, cellAddr));
+        if (s.count > 1) return;             // op + leaf are invariant; record once
+        if (op != ALU_NONE && s.opSeq.size() < 32) s.opSeq.push_back(op);
+        addLeaf(s, LK_RAM_READ, cellAddr, ramFn ? ramFn(ramCtx, cellAddr) : 0);
+    }
+
+    inline void sliceCellUpdate(uint32_t storeSlot, uint16_t cellAddr)
+    {
+        const RetiredInstr st = ring[storeSlot];
+        SiddfSummary &s = sdcu[cellAddr];
+        const uint8_t v = st.memVal;
+        if (!s.valSeen) { s.valFirst = v; s.valSeen = true; }
+        if (v < s.valLo) s.valLo = v;
+        if (v > s.valHi) s.valHi = v;
+        // mid-call value sequence (the genuine generator state stream the host
+        // feeds to Berlekamp-Massey; bounded, flat vs frames)
+        if (s.valSeq.size() < SiddfSummary::SDCU_VALSEQ_M) s.valSeq.push_back(v);
+        s.count++;
+        addPc(s, st.pc);
+        if (s.count > 32) return;             // shape invariant; refine cheaply only
+        const bool firstWalk = (s.count <= 4);
+
+        const uint32_t windowLen = ringFill < RING_CAP ? ringFill : RING_CAP;
+        const uint64_t oldestSeq = (ringSeq > windowLen) ? (ringSeq - windowLen) : 0;
+
+        SliceTask wl[128];
+        uint32_t wlHead = 0, wlTail = 0;
+        auto push = [&](SliceTask t) { if (wlTail < 128) wl[wlTail++] = t; };
+        push(SliceTask{ storeSlot, storeSrcReg(st.opcode), 0, true });
+
+        uint32_t resolved = 0;
+        while (wlHead < wlTail && resolved < 256)
+        {
+            SliceTask t = wl[wlHead++];
+            ++resolved;
+            if (!t.isReg)
+            {
+                const uint16_t a = t.mem;
+                // Do not chase the cell's own prior value (self-referential
+                // accumulator) -- record it as a state leaf and stop. This is the
+                // recurrence s' = f(s, ...): s itself is a leaf of f.
+                if (a == cellAddr)
+                {
+                    addLeaf(s, LK_RAM_READ, a, ramFn ? ramFn(ramCtx, a) : 0);
+                    continue;
+                }
+                const uint64_t wseq = lastWriteSeq[a];
+                if (wseq != 0 && (wseq - 1) >= oldestSeq && (wseq - 1) < ringSeq)
+                {
+                    const uint32_t wslot = lastWriteSlot[a];
+                    if (ring[wslot].ringSeq == (wseq - 1) && ring[wslot].memWrite &&
+                        ring[wslot].memAddr == a)
+                    {
+                        RetiredInstr &w = ring[wslot];
+                        addPc(s, w.pc);
+                        if (isStore(w.opcode))
+                        {
+                            push(SliceTask{ wslot, storeSrcReg(w.opcode), 0, true });
+                            if (w.idxUsed != SR_NONE)
+                                push(SliceTask{ wslot, w.idxUsed, 0, true });
+                        }
+                        else
+                        {
+                            const uint8_t op = aluOp(w.opcode);
+                            if (firstWalk && op != ALU_NONE && s.opSeq.size() < 32)
+                                s.opSeq.push_back(op);
+                            addLeaf(s, LK_RAM_READ, a, ramFn ? ramFn(ramCtx, a) : 0);
+                        }
+                        continue;
+                    }
+                }
+                addLeaf(s, LK_RAM_READ, a, ramFn ? ramFn(ramCtx, a) : 0);
+                continue;
+            }
+            bool found = false;
+            uint32_t idx = t.anchor;
+            for (uint32_t steps = 0; steps < windowLen; ++steps)
+            {
+                idx = (idx == 0) ? (RING_CAP - 1) : (idx - 1);
+                RetiredInstr &in = ring[idx];
+                const uint8_t dr = defReg(in.opcode);
+                const bool defs = (dr == t.reg) ||
+                                  (t.reg == SR_X && alsoDefsX(in.opcode));
+                if (!defs) continue;
+                found = true;
+                addPc(s, in.pc);
+                const uint8_t a = aluOp(in.opcode);
+                if (firstWalk && dr == SR_A && a != ALU_NONE && s.opSeq.size() < 32)
+                    s.opSeq.push_back(a);
+                if (readsMem(in.opcode) && (in.memRead || in.memWrite))
+                {
+                    if (in.idxUsed != SR_NONE)
+                    {
+                        if (!s.hasStride) { s.hasStride = true; s.strideBase = in.idxBase; }
+                        const uint8_t iv = in.idxVal;
+                        if (iv < s.strideIdxMin) s.strideIdxMin = iv;
+                        if (iv > s.strideIdxMax) s.strideIdxMax = iv;
+                        push(SliceTask{ idx, in.idxUsed, 0, true });
+                    }
+                    push(SliceTask{ idx, 0, in.memAddr, false });
+                }
+                else
+                {
+                    switch (in.opcode)
+                    {
+                    case 0x8A: push(SliceTask{ idx, SR_X, 0, true }); break;
+                    case 0x98: push(SliceTask{ idx, SR_Y, 0, true }); break;
+                    case 0xAA: case 0xA8: push(SliceTask{ idx, SR_A, 0, true }); break;
+                    default: break;
+                    }
+                    if (firstWalk && in.hasImm &&
+                        (in.opcode == 0xA9 || in.opcode == 0xA2 || in.opcode == 0xA0 ||
+                         a == ALU_ADC || a == ALU_SBC || a == ALU_AND ||
+                         a == ALU_ORA || a == ALU_EOR || a == ALU_CMP ||
+                         in.opcode == 0xAB || in.opcode == 0x4B ||
+                         in.opcode == 0x0B || in.opcode == 0x2B ||
+                         in.opcode == 0x6B || in.opcode == 0xCB))
+                        addImmOrSmcLeaf(s, in);
+                }
+                break;
+            }
+            if (!found) addLeaf(s, LK_OUT_OF_WINDOW, 0, 0);
+        }
+    }
+
+    // Record an immediate-operand leaf, but if the operand byte is a self-modified
+    // operand (EXEC&WRITE during play -- the DefMon compiled-player class), record
+    // it as a STATE_CELL leaf at the operand ADDRESS instead of a constant: the
+    // value the axis writes is that poked byte, so its inter-frame sequence (the
+    // operand's own write stream) IS the generator. Its update slice is seeded at
+    // write time (isStateWrite in beginInstr) and its STATESEQ is gathered because
+    // isSiddfStateCell now sees this leaf. (design 1.3 SMC / 2.3 / 2.5)
+    inline void addImmOrSmcLeaf(SiddfSummary &s, const RetiredInstr &in)
+    {
+        // Provisionally record a candidate SMC operand as a RAM_READ leaf at the
+        // operand ADDRESS; finalizeLeaves() upgrades it to LK_STATE_CELL iff the
+        // final access-type map says it is EXEC&WRITE_PLAY (and otherwise leaves it
+        // as a RAM constant). A genuine constant immediate (operand never written)
+        // is recorded as LK_IMMEDIATE as before.
+        if (in.hasImm && in.immAddr && isSmcOperandCandidate(in.immAddr))
+            addLeaf(s, LK_RAM_READ, in.immAddr,
+                    ramFn ? ramFn(ramCtx, in.immAddr) : in.imm);
+        else
+            addLeaf(s, LK_IMMEDIATE, 0, in.imm);
+    }
+
+    // ----- the bounded backward dynamic slicer ------------------------------
+    // ringIdx is the ring slot of the just-retired STA/STX/STY $D4xx. Build the
+    // backward dynamic slice of the stored value over the ring buffer. Each task
+    // is resolved by a LOCAL backward scan from its anchor slot: register tasks
+    // stop at the nearest prior definer; memory tasks jump directly to the last
+    // writer of that address (via lastWriteSlot), which may be MANY instructions
+    // back (a persistent state cell updated only on a note-change frame) -- this
+    // is how cross-frame state/def edges enter the slice without unbounding the
+    // ring. Records: slice PCs, classified leaves, value-chain ALU ops, and any
+    // indexed-read strided interval, all keyed to this store's (PC,reg). All sets
+    // are bounded; a def that has fallen out of the ring is an out-of-window leaf.
+    inline void sliceSidWrite(uint32_t ringIdx)
+    {
+        const RetiredInstr st = ring[ringIdx];
+        const uint8_t reg = (uint8_t)(st.memAddr & 0x1f);
+        const uint32_t key = ((uint32_t)st.pc << 5) | reg;
+        SiddfSummary &s = siddf[key];
+
+        if (!s.valSeen) { s.valFirst = st.memVal; s.valSeen = true; }
+        if (st.memVal < s.valLo) s.valLo = st.memVal;
+        if (st.memVal > s.valHi) s.valHi = st.memVal;
+        s.count++;
+        addPc(s, st.pc);
+
+        // The slice shape/op-seq is invariant across frames; do the full walk only
+        // for the first N occurrences (later walks would not grow the union). The
+        // strided interval still refines on every walk (cheap).
+        if (s.count > 32) return;
+        const bool firstWalk = (s.count == 1);
+
+        const uint32_t windowLen = ringFill < RING_CAP ? ringFill : RING_CAP;
+        const uint64_t oldestSeq = (ringSeq > windowLen) ? (ringSeq - windowLen) : 0;
+
+        // Bounded worklist (FIFO). Caps keep the walk O(code-sites)-bounded.
+        SliceTask wl[128];
+        uint32_t wlHead = 0, wlTail = 0;
+        auto push = [&](SliceTask t) { if (wlTail < 128) wl[wlTail++] = t; };
+
+        // resolved-task memo to avoid revisiting (small fixed table)
+        push(SliceTask{ ringIdx, storeSrcReg(st.opcode), 0, true });
+
+        uint32_t resolved = 0;
+        while (wlHead < wlTail && resolved < 256)
+        {
+            SliceTask t = wl[wlHead++];
+            ++resolved;
+
+            if (!t.isReg)
+            {
+                // Resolve a memory address: jump to its last writer if resident.
+                const uint16_t a = t.mem;
+                const uint64_t wseq = lastWriteSeq[a];      // 0 = never written
+                if (wseq != 0 && (wseq - 1) >= oldestSeq && (wseq - 1) < ringSeq)
+                {
+                    const uint32_t wslot = lastWriteSlot[a];
+                    // confirm the slot still holds that exact writer (not wrapped)
+                    if (ring[wslot].ringSeq == (wseq - 1) && ring[wslot].memWrite &&
+                        ring[wslot].memAddr == a)
+                    {
+                        RetiredInstr &w = ring[wslot];
+                        addPc(s, w.pc);
+                        if (isStore(w.opcode))
+                        {
+                            push(SliceTask{ wslot, storeSrcReg(w.opcode), 0, true });
+                            if (w.idxUsed != SR_NONE)
+                                push(SliceTask{ wslot, w.idxUsed, 0, true });
+                        }
+                        else
+                        {   // in-place RMW (INC/DEC/ASL on memory): new = op(old).
+                            // The cell IS persistent state (its prior value carries
+                            // between calls); record it as a state leaf and the op,
+                            // but do NOT chase its prior value (that would loop on
+                            // the same self-referential cell). This is the counter
+                            // recurrence s' = s + 1 / s - 1.
+                            const uint8_t op = aluOp(w.opcode);
+                            if (firstWalk && op != ALU_NONE && s.opSeq.size() < 32)
+                                s.opSeq.push_back(op);
+                            addLeaf(s, LK_RAM_READ, a, ramFn ? ramFn(ramCtx, a) : 0);
+                        }
+                        continue;
+                    }
+                }
+                // No resident writer: it is a LEAF (constant / persistent state /
+                // exogenous), classified against the final access-type map later.
+                addLeaf(s, LK_RAM_READ, a, ramFn ? ramFn(ramCtx, a) : 0);
+                // If this cell is a persistent state cell that was FILLED (on a
+                // far-earlier frame, out of the ring) by a store whose value came
+                // from a table read / arithmetic, link that filler's findings to
+                // this axis -- this is how the note-table read attributes to the
+                // freq SID-write site even though a held note's table read is many
+                // frames back. (design 2.3/2.4: persistent state entering the slice
+                // + the array K the filler dereferenced.)
+                // Merge on ANY walk (not just the first): a held note's filler is
+                // only populated once the note first CHANGES, which may be after
+                // this site's first walk. The merge is idempotent -- stride,
+                // leaves and PCs dedup; op_seq is taken once (when still empty).
+                if (!filler.empty() && filler[a].updated)
+                {
+                    const FillerSlice &fs = filler[a];
+                    if (fs.hasStride && !s.hasStride)
+                    {
+                        s.hasStride = true;
+                        s.strideBase = fs.strideBase;
+                        if (fs.idxMin < s.strideIdxMin) s.strideIdxMin = fs.idxMin;
+                        if (fs.idxMax > s.strideIdxMax) s.strideIdxMax = fs.idxMax;
+                    }
+                    if (fs.hasSrcAddr)
+                        addLeaf(s, LK_RAM_READ, fs.srcAddr,
+                                ramFn ? ramFn(ramCtx, fs.srcAddr) : 0);
+                    // feedsRegMask (item #5): the filler's indexed reads also feed
+                    // this SID register (the held-note table read attributes here).
+                    if (reg <= 24)
+                        for (uint8_t i = 0; i < fs.nPcs; ++i)
+                        {
+                            auto it = idxReads.find(fs.pcs[i]);
+                            if (it != idxReads.end())
+                                it->second.feedsRegMask |= (1u << reg);
+                        }
+                    for (uint8_t i = 0; i < fs.nPcs; ++i) addPc(s, fs.pcs[i]);
+                    if (s.opSeq.empty())
+                        for (uint8_t i = 0; i < fs.nOps && s.opSeq.size() < 32; ++i)
+                            s.opSeq.push_back(fs.ops[i]);
+                }
+                continue;
+            }
+
+            // Resolve a register: scan strictly backward from the anchor slot to
+            // the nearest prior instruction that defines it.
+            bool found = false;
+            uint32_t idx = t.anchor;
+            for (uint32_t steps = 0; steps < windowLen; ++steps)
+            {
+                idx = (idx == 0) ? (RING_CAP - 1) : (idx - 1);
+                RetiredInstr &in = ring[idx];
+                const uint8_t dr = defReg(in.opcode);
+                const bool defs = (dr == t.reg) ||
+                                  (t.reg == SR_X && alsoDefsX(in.opcode));
+                if (!defs) continue;
+
+                found = true;
+                addPc(s, in.pc);
+                const uint8_t a = aluOp(in.opcode);
+                if (firstWalk && dr == SR_A && a != ALU_NONE && s.opSeq.size() < 32)
+                    s.opSeq.push_back(a);
+
+                if (readsMem(in.opcode) && (in.memRead || in.memWrite))
+                {
+                    if (in.idxUsed != SR_NONE)
+                    {
+                        if (!s.hasStride) { s.hasStride = true; s.strideBase = in.idxBase; }
+                        const uint8_t iv = in.idxVal;
+                        if (iv < s.strideIdxMin) s.strideIdxMin = iv;
+                        if (iv > s.strideIdxMax) s.strideIdxMax = iv;
+                        push(SliceTask{ idx, in.idxUsed, 0, true });
+                    }
+                    // feedsRegMask (item #5): this indexed read's PC is an IDXR
+                    // table walk whose value flows to SID register `reg`; tag the
+                    // IDXR entry so the host knows which $D4xx lane this table
+                    // feeds (the reg attribution the slice already carries).
+                    if (in.idxUsed != SR_NONE && reg <= 24)
+                    {
+                        auto it = idxReads.find(in.pc);
+                        if (it != idxReads.end())
+                            it->second.feedsRegMask |= (1u << reg);
+                    }
+                    push(SliceTask{ idx, 0, in.memAddr, false });
+                }
+                else
+                {
+                    const uint8_t a2 = aluOp(in.opcode);
+                    switch (in.opcode)
+                    {
+                    case 0x8A: push(SliceTask{ idx, SR_X, 0, true }); break; // TXA
+                    case 0x98: push(SliceTask{ idx, SR_Y, 0, true }); break; // TYA
+                    case 0xAA: case 0xA8: push(SliceTask{ idx, SR_A, 0, true }); break;
+                    default: break;
+                    }
+                    if (firstWalk && in.hasImm &&
+                        (in.opcode == 0xA9 || in.opcode == 0xA2 || in.opcode == 0xA0 ||
+                         a2 == ALU_ADC || a2 == ALU_SBC || a2 == ALU_AND ||
+                         a2 == ALU_ORA || a2 == ALU_EOR || a2 == ALU_CMP))
+                        addImmOrSmcLeaf(s, in);
+                }
+                break;
+            }
+            if (!found) addLeaf(s, LK_OUT_OF_WINDOW, 0, 0);
+        }
+    }
+
+public:
+    // Reclassify every memory leaf against the FINAL access-type map. Called once
+    // after the run, before serialization. Immediate and out-of-window leaves are
+    // left as-is; memory leaves (recorded provisionally as RAM_READ during the
+    // bounded walk) are upgraded to STATE_CELL / EXOGENOUS / RAM_READ per their
+    // accumulated access type (design 2.3): this is the SMC-correct classifier.
+    void finalizeLeaves()
+    {
+        for (auto &kv : siddf)
+            for (auto &l : kv.second.leaves)
+                if (l.kind == LK_RAM_READ)
+                    l.kind = classifyLeaf(l.addr);
+        for (auto &kv : sdcu)
+            for (auto &l : kv.second.leaves)
+                if (l.kind == LK_RAM_READ)
+                    l.kind = classifyLeaf(l.addr);
+    }
+
+    // Is `addr` flagged as a state cell by some SIDDF site (after finalizeLeaves)?
+    // Used to filter STATESEQ down to the cells the host actually needs to fit a
+    // recurrence for -- the handful the slices surfaced -- keeping the section
+    // small. Call AFTER finalizeLeaves().
+    bool isSiddfStateCell(uint16_t addr) const
+    {
+        for (const auto &kv : siddf)
+            for (const auto &l : kv.second.leaves)
+                if (l.kind == LK_STATE_CELL && l.addr == addr)
+                    return true;
+        return false;
+    }
+
+    // Finalize the recovery-offload captures (items #1, #5, #7). Call AFTER
+    // finalizeLeaves(). `loadLo`/`loadHi` bound the loaded image span (for the
+    // pointer-table target-in-image signal).
+    //  - IDXR scale fit: from the two distinct-index samples, scale = (a1-a0)/
+    //    (i1-i0) when it divides exactly, base = a0 - scale*i0.
+    //  - IDXR targetsInImage/targetsReadAsData: read the 16-bit values formed at
+    //    base+idx across the swept index range from the snapshot; if those target
+    //    addresses land in the image (and were read as data during play), this is
+    //    a pointer table.
+    //  - SIDDF accumulated: a write whose slice has a leaf state cell that was
+    //    written by >=2 distinct PCs in one frame is tagged accumulated, with the
+    //    contributing (op, cell) addends.
+    void finalizeOffload(uint16_t loadLo, uint16_t loadHi)
+    {
+        for (auto &kv : idxReads)
+        {
+            IdxSummary &s = kv.second;
+            // affine scale/base fit from two distinct-index samples
+            if (s.nSamp == 2 && s.sampIdx[1] != s.sampIdx[0])
+            {
+                const int32_t da = (int32_t)s.sampAddr[1] - (int32_t)s.sampAddr[0];
+                const int32_t di = (int32_t)s.sampIdx[1] - (int32_t)s.sampIdx[0];
+                if (di != 0 && (da % di) == 0)
+                {
+                    s.scale = da / di;
+                    s.baseFit = (uint16_t)((int32_t)s.sampAddr[0] -
+                                           s.scale * (int32_t)s.sampIdx[0]);
+                    s.scaleSet = true;
+                }
+            }
+            if (!s.scaleSet) { s.scale = 1; s.baseFit = s.base; }
+            // pointer-table target signals: form the 16-bit little-endian targets
+            // at (baseFit + scale*idx) over the swept index range, from the
+            // snapshot, and test whether they resolve in-image / read-as-data.
+            if (ramSnapshotTaken && loadHi > loadLo)
+            {
+                bool anyIn = false, anyRead = false, anyTarget = false;
+                const int lo = s.idxMin, hi = s.idxMax;
+                for (int i = lo; i <= hi && i <= 255; ++i)
+                {
+                    const int32_t ea = (int32_t)s.baseFit + s.scale * i;
+                    if (ea < 0 || ea + 1 > 0xffff) continue;
+                    const uint16_t tgt = (uint16_t)(ramSnapshot[ea] |
+                                                    (ramSnapshot[ea + 1] << 8));
+                    anyTarget = true;
+                    if (tgt >= loadLo && tgt < loadHi)
+                    {
+                        anyIn = true;
+                        if (acc[tgt] & ACC_READ_PLAY) anyRead = true;
+                    }
+                }
+                if (anyTarget) { s.targetsInImage = anyIn; s.targetsReadAsData = anyRead; }
+            }
+        }
+        // SIDDF accumulated propagation (item #7).
+        for (auto &kv : siddf)
+        {
+            SiddfSummary &s = kv.second;
+            for (const auto &l : s.leaves)
+            {
+                if (l.kind != LK_STATE_CELL) continue;
+                auto it = accumTrack.find(l.addr);
+                if (it == accumTrack.end() || !it->second.multiWritten) continue;
+                s.accumulated = true;
+                const AccumTrack &a = it->second;
+                for (uint8_t i = 0; i < a.nWriters; ++i)
+                {
+                    bool have = false;
+                    for (const auto &ad : s.addends)
+                        if (ad.cell == l.addr && ad.op == a.writerOps[i]) { have = true; break; }
+                    if (!have && s.addends.size() < 32)
+                        s.addends.push_back(SiddfSummary::Addend{ a.writerOps[i], l.addr });
+                }
+            }
+        }
+    }
+
+};
+
+} // namespace libsidplayfp
+
+#endif // MEMBUS_TRACE_H
